# Copy to server/.env and fill in. dev works with the defaults below.
# Secret used to sign session JWTs — set a long random string in production.
JWT_SECRET=dev-insecure-secret-change-me
# API port (the frontend dev proxy points at this).
PORT=3001
# The static frontend's origin, for CORS when the API is deployed separately.
CLIENT_ORIGIN=http://localhost:5173
# Set NODE_ENV=production in prod so the session cookie is Secure + SameSite=None.
# DB_PATH=/data/pitchside.db   # point at a persistent volume in production
